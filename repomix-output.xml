        x = LSTM(128, activation='relu', return_sequences=True,
                 kernel_regularizer=l2(l2_reg))(x)
        x = Dropout(dropout)(x)
        x = LSTM(64, activation='relu', return_sequences=True,
                 kernel_regularizer=l2(l2_reg))(x)
