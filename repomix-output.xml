    'Pista de Silla': {'lat': 39.4581, 'lon': -0.3766},
    'Politécnico': {'lat': 39.4796, 'lon': -0.3374},
    'Universidad Politécnica': {'lat': 39.4796, 'lon': -0.3374},
    'Viveros': {'lat': 39.4796, 'lon': -0.3696},
    'Valencia Centro': {'lat': 39.4705, 'lon': -0.3764},
