def lens_table_forecast_snapshot(title: str, kuery: str) -> dict:

    layer_id = "layer1"
    c_st, c_h, c_pm, c_no2, c_o3 = "t1", "t2", "m1", "m2", "m3"
    cols = {
        c_st: _col_terms("station.keyword", "Estación", size=25),
