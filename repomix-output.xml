import os
import logging
from datetime import datetime
import re

logger = logging.getLogger(__name__)


STATION_COORDS = {
    'Avda. Francia': {'lat': 39.4578, 'lon': -0.343},
    'Francia': {'lat': 39.4578, 'lon': -0.343},
    'Bulevard Sud': {'lat': 39.4504, 'lon': -0.3963},
    'Boulevar Sur': {'lat': 39.4504, 'lon': -0.3963},
