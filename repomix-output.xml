MONGO_URI = os.getenv('MONGO_URI')

STATION_NAME_PG = 'Pista de Silla'
STATION_ID_MONGO = '8416Y'

def get_postgres_data():

    conn = psycopg2.connect(
        host=POSTGRES_HOST, port=POSTGRES_PORT,
